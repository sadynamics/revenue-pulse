# Server
PORT=3000
NODE_ENV=production

# Database file location (Railway volume önerilir, örn: /data/revenue.db)
DB_PATH=./data/revenue.db

# --- Apple App Store Server Notifications V2 ---
#
# Bu sistem **birden fazla uygulamayı** aynı dashboard üzerinden takip edebilir.
# Apple App Store Server API key'i Developer team'ine bağlıdır, app başına
# değildir — yani aynı team'deki tüm app'ler için tek bir key yeter.
#
# Tipik (önerilen) kurulum: Aşağıdaki APPSTORE_ISSUER_ID / APPSTORE_KEY_ID /
# APPSTORE_PRIVATE_KEY env'lerini bir kere doldurun, sonra her app için sadece
# `id` + `bundle_id` listeleyin:
#
#   APPS_CONFIG='[
#     {"id":"myapp",   "name":"MyApp",     "bundle_id":"com.acme.myapp"},
#     {"id":"otherapp","name":"OtherApp",  "bundle_id":"com.acme.other","environment":"Sandbox"}
#   ]'
#
# Farklı bir Developer team'inde olan bir app varsa, sadece o app için per-app
# override koyabilirsiniz (içinde `issuer_id`, `key_id`, `private_key` —
# veya `private_key_path` — alanlarını ekleyerek).
#
# Tek app kullanıyorsanız `APPS_CONFIG`'i hiç set etmeyin; aşağıdaki tek-app
# `APPSTORE_BUNDLE_ID` / `APPSTORE_ENVIRONMENT` değerleri otomatik default app
# olarak yüklenir (geriye uyumluluk).
#
# Webhook routing: Apple notification içindeki `data.bundleId` ile eşleşen app
# bulunur. Eşleşme yoksa default app'e (ilk app) düşer + warning loglanır.
# Bilinmeyen bundle'ları reddetmek için `STRICT_BUNDLE_ID=true` set edin.

# (A) Çoklu app konfigürasyonu (tek satır JSON)
# APPS_CONFIG='[]'

# (B) Tek app — APPS_CONFIG boşsa kullanılır
APPSTORE_BUNDLE_ID=com.acme.app
APPSTORE_ENVIRONMENT=Production

# Bilinmeyen bundle'lardan gelen webhook'ları reddet (default: false → default app'e fallback)
# STRICT_BUNDLE_ID=false

# İmza doğrulama. "true" yapılırsa x5c chain doğrulaması atlanır — sadece dev/test için!
# Prod'da hep "false" olmalı.
APPSTORE_SKIP_VERIFICATION=false

# Apple Root CA sertifikası (PEM). Verilirse x5c zinciri bu root'a kadar doğrulanır.
# İndirin: https://www.apple.com/certificateauthority/AppleRootCA-G3.cer
# .cer → PEM'e çevirin: openssl x509 -inform der -in AppleRootCA-G3.cer -out AppleRootCA-G3.pem
# APPLE_ROOT_CERT_PATH=./certs/AppleRootCA-G3.pem

# --- App Store Server API (transaction history backfill) ---
#
# Bu credential'lar Developer team'i bazında tanımlanır ve tüm app'ler için
# default olarak kullanılır. Per-app override istiyorsanız APPS_CONFIG içindeki
# ilgili app'e `issuer_id` / `key_id` / `private_key` (veya `private_key_path`)
# ekleyin.
#
# Set edildiğinde:
#   1. Yeni bir subscriber ilk webhook'ta görüldüğünde, geçmiş tüm satın alımları
#      otomatik olarak Apple'dan çekilir (one-time, lifetime, consumable dahil).
#   2. Subscriber detayında "🔄 Sync from App Store" butonu kullanılabilir.
#   3. `npm run backfill` ile tüm DB toplu olarak senkronlanabilir
#      (`-- --app <id>` ile tek app, yoksa tüm app'ler).
#
# Key oluşturma: App Store Connect → Users and Access → Integrations → In-App Purchase
# → Generate API Key. Key ID, Issuer ID ve indirilen .p8 dosyasını saklayın.

# Issuer ID (UUID, App Store Connect Integrations sayfasının üstünde)
# APPSTORE_ISSUER_ID=00000000-0000-0000-0000-000000000000

# Key ID (10 karakter, oluşturduğunuz key'in yanında)
# APPSTORE_KEY_ID=ABCDEF1234

# .p8 private key. İki seçenek:
#   (a) PEM string'i doğrudan env'e koyun (Railway'de en kolay yol).
#       Newline'lar literal "\n" olarak yazılmalıdır.
# APPSTORE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIG...\n-----END PRIVATE KEY-----\n"
#   (b) ya da dosya yolu verin:
# APPSTORE_PRIVATE_KEY_PATH=/app/certs/AuthKey_ABCDEF1234.p8

# Reconcile scheduler (Apple canlı state ile DB drift düzeltme)
# Her N saatte bir aktif kullanıcıları kontrol eder; kaçmış expiration/refund gibi
# event'leri synthetic ingest ile düzeltir.
APPSTORE_RECONCILE_ENABLED=true
APPSTORE_RECONCILE_INTERVAL_HOURS=24
APPSTORE_RECONCILE_BATCH_LIMIT=200

# --- Dashboard auth (opsiyonel) ---
DASHBOARD_USER=admin
DASHBOARD_PASS=change-me

# Varsayılan para birimi (transaction'da currency yoksa kullanılır)
DEFAULT_CURRENCY=USD

# --- Telegram bildirimleri (opsiyonel ama önerilir) ---
#
# Açıldığında her ingest edilen event için telefonuna anlık push gelir
# (RevenueCat'in mobil uygulamasında gördüğün liste mantığında — bayrak,
# ürün, fiyat, app, "1h ago", durum badge'i). Ayrıca her gün belirlediğin
# saatte günlük net gelir + uygulama bazlı kırılım özeti yollanır.
#
# Kurulum (5 dakika):
#   1) Telegram'da @BotFather'a yaz → /newbot → bota isim ver → token al.
#   2) Yarattığın bota Telegram üzerinden "/start" gönder ki sana mesaj
#      yollayabilsin.
#   3) Chat ID'ni öğrenmek için tarayıcıda aç:
#      https://api.telegram.org/bot<TOKEN>/getUpdates
#      `chat.id` alanı senin sayısal ID'in (kişi: pozitif, grup: negatif).
#   4) Aşağıdaki iki env'i doldur ve servisi yeniden başlat.
#   5) `POST /api/notify/test` ile bağlantıyı test et.

# TELEGRAM_BOT_TOKEN=123456789:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
# TELEGRAM_CHAT_ID=987654321

# Hangi event tipleri push edilsin? Boş = sensible default
# (INITIAL_PURCHASE, RENEWAL, NON_RENEWING_PURCHASE, PRODUCT_CHANGE,
#  UNCANCELLATION, CANCELLATION, EXPIRATION, BILLING_ISSUE,
#  SUBSCRIPTION_PAUSED, REFUND, REVOKE, TEST). "*" = hepsi.
# NOTIFY_EVENT_TYPES=*

# N dakikadan eski event'ler push'lanmaz (backfill/reconcile sırasında
# ekrana 50 push düşmesini engeller). 0 = filtre yok.
NOTIFY_MAX_EVENT_AGE_MINUTES=60

# Sandbox event'leri de push'lansın mı? (true/false)
NOTIFY_INCLUDE_SANDBOX=true

# Her push'ın altına o günün net gelir özetini ekle ("Today: $123.45 net").
NOTIFY_SHOW_DAILY_TOTAL=true

# Günlük özet (digest) açık mı?
NOTIFY_DAILY_DIGEST_ENABLED=true

# Hangi UTC saatinde gönderilsin? (0–23). 6 ≈ Türkiye saati 09:00.
NOTIFY_DAILY_DIGEST_UTC_HOUR=6

# Telegram rate-limit safety: aynı chat'e ardışık iki mesaj arası ms.
# Telegram limiti ≈ 1 msg/sec/chat. 350 ms güvenli ve hızlıdır.
# TELEGRAM_QUEUE_GAP_MS=350
